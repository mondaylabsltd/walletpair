{
  "name": "walletpair-extension",
  "description": "WalletPair - Bridge any dApp to your wallet via WalletPair protocol",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "tsx e2e/extension.e2e.ts",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "lucide-svelte": "^1.0.1",
    "qrcode": "^1.5.4",
    "walletpair-sdk": "^1.1.0"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.8",
    "@types/chrome": "^0.0.304",
    "@types/qrcode": "^1.5.5",
    "@wxt-dev/module-svelte": "^2.0.4",
    "puppeteer": "^25.0.4",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "tslib": "^2.8.1",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6",
    "wxt": "^0.20.26"
  }
}